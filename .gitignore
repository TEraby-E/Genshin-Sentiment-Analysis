# 数据文件（体积大，从 Kaggle 下载，不纳入版本控制）
data/*.csv

# 抓取缓存与监控快照（运行时产物）
data/cache/
data/snapshots/

# uv / Python 虚拟环境
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# 分析产出（可选：若想保留示例图表，注释掉下一行）
outputs/*.png

# 密钥与环境变量（API key 绝不入库）
.env
*.key

# 训练好的轻量模型（运行时产物，可由 train_sentiment.py 重新生成）
*.joblib

# LoRA 训练的中间产物：优化器/调度器状态等，体积大且无需入库（只保留根目录的最终适配器）
outputs/finetune/**/checkpoint-*/
outputs/finetune/**/optimizer.pt
outputs/finetune/**/scheduler.pt
outputs/finetune/**/rng_state*.pth
outputs/finetune/**/trainer_state.json
outputs/finetune/**/global_step*/

# 系统
.DS_Store
.idea/
.vscode/
