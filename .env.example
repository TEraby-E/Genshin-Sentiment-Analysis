# ============================================================================
# 环境配置：复制为 .env 并按需填写。.env 不纳入版本控制。
# 本文件集中列出项目用到的全部模型接口。
# 注意：除 DeepSeek 外，其余模型均为本地运行，不需要额外的 API key。
# ============================================================================

# ---- 模型一：DeepSeek 对话模型（在线 HTTP API）----
# 用途：AI 语义打标、舆情/爆点总结、智能路由的 RAG-DeepSeek 轨道与 LLM 校验。
# 默认接入 DeepSeek，采用 OpenAI 兼容协议，可替换为任意兼容服务的 base_url / key。
DEEPSEEK_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
# 可选调参（不填用默认）：单次打包评论数 / 失败重试次数 / 采样温度
# LLM_BATCH_SIZE=20
# LLM_MAX_RETRIES=3
# LLM_TEMPERATURE=0.0

# ---- 模型二：RAG 嵌入模型（本地）----
# 用途：把「梗 & 设定词典」与查询编码成向量做混合检索。
# 留空 = 离线哈希嵌入（零下载、无需 GPU，默认即可用）；
# 填 sentence-transformers 模型名则启用语义嵌入（需 `uv sync --extra rag`），例如：
#   RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_EMBEDDING_MODEL=
# 向量库后端：auto（优先 Chroma，缺失回退内存）/ memory（纯内存）/ chroma（强制本地持久化）
RAG_VECTOR_BACKEND=auto
# Chroma 持久化目录（仅 chroma 后端用到）
RAG_PERSIST_DIR=outputs/rag_lore

# ---- 模型三：本地 LoRA 微调大模型 Qwen2.5-7B（本地，进程内推理）----
# 用途：「本地微调大模型」打标，以及智能路由的 lora 轨道。
# 需要外接 eGPU 并 `uv sync --extra finetune`；推理由 LocalLLMClassifier 在进程内加载，
# 当前不提供本地 HTTP 服务端点。
# 基座模型：HuggingFace 仓库 id 或本地权重目录（首次加载按需下载到本地缓存）。
LORA_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
# LoRA 适配器目录：train_lora.sh 的训练产物默认落在这里，推理端与训练端共用此路径。
LORA_ADAPTER_DIR=outputs/finetune/qwen2.5-7b-lora

# ---- 模型三-B：云端自建 LoRA 端点（场景 B：本地调用 + 云端算力）----
# 用 vLLM 把微调后的 Qwen 起成 OpenAI 兼容服务（见 scripts/serve_lora.sh），
# 再用 cloudflared / ngrok 映射出公网地址，填到这里即可让智能路由的 lora_server 轨道
# 调用你自己的云端模型——本地零显存、不烧 DeepSeek 额度。留空则该轨道自动关闭。
LORA_SERVER_BASE_URL=
LORA_SERVER_MODEL=qwen2.5-7b-lora
LORA_SERVER_API_KEY=EMPTY
# 服务端不支持强制 JSON 输出时设为 0
# LORA_SERVER_JSON_MODE=1

# ---- 模型四：蒸馏本地分类器（本地，无需配置）----
# 字符级 TF-IDF + 逻辑回归，模型文件固定为 outputs/sentiment_clf.joblib，
# 由 scripts/train_sentiment.py 生成，不读取任何环境变量，此处仅作说明。
